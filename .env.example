# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://rental:change_me_in_production@postgres:5432/rental

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379

# ─── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=rental-files

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost
# Public web app URL — used to build password-reset links
APP_URL=http://localhost:5173

# ─── Encryption (PII fields) ────────────────────────────────────────────────
ENCRYPTION_KEY=change_me_32_byte_hex_key_here_!!
ENCRYPTION_IV_LENGTH=12

# ─── Email (stub) ───────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@rental.local

# ─── Telegram (rent reminders) ──────────────────────────────────────────────
# Bot token from @BotFather and the bot's @username (without the @).
# Leave empty to disable Telegram delivery (messages are logged only).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
